{
  "name": "dm-capital-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DM Capital backend — Deribit BTC options gateway",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "tsx watch src/index.ts",
    "setup": "prisma migrate dev",
    "build": "tsc && node -e \"require('fs').cpSync('src/generated','dist/generated',{recursive:true})\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "audit:snapshot": "tsx scripts/audit-snapshot.ts",
    "prisma:dev": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:generate:legacy": "prisma generate --schema prisma/schema.prisma",
    "prisma:generate:local": "prisma generate --schema prisma/local/schema.prisma",
    "prisma:generate:durable": "prisma generate --schema prisma/durable/schema.prisma",
    "prisma:generate:all": "pnpm prisma:generate:legacy && pnpm prisma:generate:local && pnpm prisma:generate:durable",
    "prisma:deploy:local": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:deploy:durable": "prisma migrate deploy --schema prisma/durable/schema.prisma",
    "prisma:studio:durable": "prisma studio --schema prisma/durable/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "@types/ws": "^8.5.13",
    "prisma": "^5.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
