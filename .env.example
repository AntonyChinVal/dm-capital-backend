# Server binding
# Use 0.0.0.0 to allow LAN access (default). Use 127.0.0.1 to restrict to localhost.
HOST=0.0.0.0
PORT=4000

# Deribit (public, no auth required)
DERIBIT_REST=https://www.deribit.com/api/v2
DERIBIT_WS=wss://www.deribit.com/ws/api/v2

# Flow scanner thresholds (BTC notional)
FLOW_STREAM_MIN_BTC=1     # visual feed minimum size
FLOW_AGG_MIN_BTC=0.1      # aggregator minimum size (Phase 8)
FLOW_LARGE_BTC=25         # threshold for "large" tag

# ── Persistence: dual-store ─────────────────────────────────────────────────
# SQLite local — cache operativa + restart-recovery (FlowAggregateSnapshot).
# En Fly: file:/data/dm-capital.db (ver fly.toml). No poner Neon acá.
DATABASE_URL="file:./data/dm-capital.db"

# Neon Postgres durable — pooled connection (runtime del backend).
# Copiar desde Neon Console → Connect → "Pooled connection" (host con -pooler).
DATABASE_URL_DURABLE="postgresql://USER:PASSWORD@ep-XXXX-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Neon direct — solo migraciones Prisma (prisma migrate deploy).
# Copiar desde Neon Console → Connect → "Direct connection" (sin -pooler).
DIRECT_URL_DURABLE="postgresql://USER:PASSWORD@ep-XXXX.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Batch flush a Postgres (ms). Recomendado prod: 600000 = 10 min (menor costo Neon).
# Local test rápido: 30000 = 30s. Ver docs/PERSISTENCE_SPLIT_PLAN.md.
PERSIST_FLUSH_INTERVAL_MS=600000

# Prisma query logging (0 = off, 1 = warn+error)
# PRISMA_LOG=0

# ── History retention ───────────────────────────────────────────────────────
# General (MetricSnapshot, SurfaceSnapshot, IndexTick, AlertLog)
HISTORY_RETENTION_DAYS=90

# Trades crudos para debug/export — no son el dataset principal de backtesting.
FLOW_TRADE_RETENTION_DAYS=30

# DVOL serie para rank/percentil — poda a 365d (no mezclar con signal_snapshot)
DVOL_RETENTION_DAYS=365

# SQLite local/restart-recovery — mantener chico para no llenar /data en Fly.
FLOW_AGGREGATE_RETENTION_HOURS=48
